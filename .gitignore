# Keep bulky follow-up runner outputs local unless explicitly curated.
mprotect-shared-dirty-toggle/mm-unstable-lab-sanity/lab_*/
mprotect-shared-dirty-toggle/mm-unstable-lab-sanity/lab-logs-*/
mprotect-shared-dirty-toggle/mm-unstable-lab-sanity/lab-launch-*.log
mprotect-shared-dirty-toggle/mm-unstable-local-sanity/local_*/
mprotect-shared-dirty-toggle/state-audit-lab/lab_*/
mprotect-shared-dirty-toggle/state-audit-lab/lab-logs-*/
mprotect-shared-dirty-toggle/state-audit-lab/lab-launch-*.log

# Attribution raw traces/logs can be large; keep published notes in
# attribution/summaries/ and scripts/ unless a maintainer asks for raw logs.
madvise-pageout-thp-noswap-refault/attribution/runs/

# Lab orchestration scratch logs under analysis are local staging material.
analysis/lab-followup-*/
analysis/lab-launch-*.log

# Upstream mail drafts and local send notes are review material, not public
# evidence. Keep them local unless the user explicitly asks to publish one.
email/
*/email/

# Standalone reproducer validation keeps curated summaries and run metadata
# public; raw runner directories and verbose logs remain local unless requested.
mprotect-shared-dirty-toggle/reproducer-validation/raw/
mprotect-shared-dirty-toggle/reproducer-validation/lab-raw-*/
mprotect-shared-dirty-toggle/reproducer-validation/*.log

# Bare-metal kernel-queue scratch state. Keep summaries, logs, and env files
# public when curated, but not local queue cursors or copied test binaries.
mprotect-shared-dirty-toggle/bare-metal/**/next_step
mprotect-shared-dirty-toggle/bare-metal/**/steps/
mprotect-shared-dirty-toggle/bare-metal/**/runs/bin/
